<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AgriGameController" prefWidth="900" prefHeight="600" style="-fx-background-color: #f7faf6;">

    <top>
        <HBox spacing="12" style="-fx-padding: 12 16 12 16; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <children>
                <Label text="🎮 Jeu AGRI" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1a3318;" />
                <Label fx:id="dayLabel" text="Jour 1" style="-fx-font-size:13px; -fx-text-fill:#6b7280;" />
                <Label fx:id="scoreLabel" text="Score: 0" style="-fx-font-size:13px; -fx-text-fill:#6b7280; -fx-padding:0 0 0 12;" />
            </children>
        </HBox>
    </top>

    <center>
        <GridPane fx:id="grid" hgap="10" vgap="10" style="-fx-padding:20; -fx-alignment: center;" />
    </center>

    <right>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 0 1;" prefWidth="300">
            <children>
                <Label text="Contrôles" style="-fx-font-size:14px; -fx-font-weight:600;" />
                <Button fx:id="plantBtn" text="Planter" prefWidth="240" />
                <Button fx:id="waterBtn" text="Arroser" prefWidth="240" />
                <Button fx:id="harvestBtn" text="Récolter" prefWidth="240" />
                <Button fx:id="advanceBtn" text="Avancer d'un jour" prefWidth="240" />
                <Button fx:id="adviceBtn" text="Conseil IA" prefWidth="240" />
                <Button fx:id="puzzleBtn" text="🧩 Puzzle" prefWidth="240" />
                <Button fx:id="resetBtn" text="Réinitialiser" prefWidth="240" />
                <Label text="Journal" style="-fx-font-size:14px; -fx-font-weight:600; -fx-padding:10 0 0 0;" />
                <TextArea fx:id="logArea" prefRowCount="8" wrapText="true" editable="false" prefWidth="260" />
                <HBox spacing="8">
                    <children>
                        <Button fx:id="backBtn" text="← Retour" />
                        <Label fx:id="selectedLabel" text="Aucune parcelle sélectionnée" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </right>

</BorderPane>
