<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="520.0" prefWidth="420.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.ResetPasswordController"
            style="-fx-background-color: #f7f9f4;">

    <center>
        <VBox alignment="CENTER" spacing="12" prefWidth="320"
              BorderPane.alignment="CENTER"
              style="-fx-padding: 40;">
            <children>

                <!-- Logo -->
                <ImageView fitWidth="120" fitHeight="120" preserveRatio="true">
                    <image>
                        <Image url="@/assets/logoo.png"/>
                    </image>
                </ImageView>

                <!-- Subtitle -->
                <Label text="Réinitialisation du mot de passe"
                       style="-fx-font-size: 14px; -fx-text-fill: #6f8a6d;" />

                <!-- Choix méthode -->
                <HBox alignment="CENTER" spacing="15">
                    <children>
                        <RadioButton fx:id="rbEmail" text="Email" selected="true"/>
                        <RadioButton fx:id="rbSMS" text="SMS"/>
                    </children>
                </HBox>

                <!-- Email -->
                <TextField fx:id="tfEmail"
                           promptText="Adresse e-mail"
                           prefHeight="44" prefWidth="260"
                           style="-fx-background-radius: 10;
                                  -fx-border-radius: 10;
                                  -fx-border-color: #c8dcc5;
                                  -fx-background-color: #f7f9f4;" />

                <!-- Téléphone -->
                <TextField fx:id="tfPhone"
                           promptText="Numéro téléphone"
                           disable="true"
                           prefHeight="44" prefWidth="260"
                           style="-fx-background-radius: 10;
                                  -fx-border-radius: 10;
                                  -fx-border-color: #c8dcc5;
                                  -fx-background-color: #f7f9f4;" />

                <!-- Envoyer code -->
                <Button text="Envoyer le code"
                        fx:id="btnSendCode"
                        prefWidth="260" prefHeight="44"
                        onAction="#sendCodeAction"
                        style="-fx-background-color: #228B22;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;" />

                <!-- Code + Vérifier -->
                <HBox alignment="CENTER" spacing="8" prefWidth="260">
                    <children>
                        <TextField fx:id="tfCode"
                                   promptText="Code"
                                   prefHeight="40"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 10;
                                          -fx-border-radius: 10;
                                          -fx-border-color: #c8dcc5;" />
                        <Button text="Vérifier"
                                fx:id="btnVerifyCode"
                                onAction="#verifyCodeAction"/>
                    </children>
                </HBox>

                <!-- Nouveau mot de passe -->
                <PasswordField fx:id="pfNewPassword"
                               promptText="Nouveau mot de passe"
                               prefHeight="44" prefWidth="260"
                               style="-fx-background-radius: 10;
                                      -fx-border-radius: 10;
                                      -fx-border-color: #c8dcc5;" />

                <!-- Confirmation -->
                <PasswordField fx:id="pfConfirmPassword"
                               promptText="Confirmer le mot de passe"
                               prefHeight="44" prefWidth="260"
                               style="-fx-background-radius: 10;
                                      -fx-border-radius: 10;
                                      -fx-border-color: #c8dcc5;" />

                <!-- Message -->
                <Label fx:id="labelMessage"
                       style="-fx-text-fill: #d32f2f; -fx-font-size: 12px;" />

                <!-- Reset -->
                <Button text="Réinitialiser le mot de passe"
                        fx:id="btnReset"
                        prefWidth="260" prefHeight="44"
                        disable="true"
                        onAction="#resetAction"
                        style="-fx-background-color: #1a5c1a;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;" />

                <!-- Retour login -->
                <Hyperlink text="Retour à la connexion"
                           onAction="#backToLogin"
                           style="-fx-text-fill: #228B22;" />

            </children>
        </VBox>
    </center>

</BorderPane>