<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AgriChatbotController" 
             prefWidth="800" prefHeight="600" style="-fx-background-color: #f8faf8;">
    
    <top>
        <HBox spacing="15" style="-fx-padding: 16 20 16 20; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0; -fx-alignment: center-left;">
            <children>
                <Label text="🤖" style="-fx-font-size: 24px;" />
                <Label text="Assistant Agricole AgriGo" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a5c1a;" />
                <Label fx:id="statusLabel" text="🟢 En ligne" style="-fx-font-size: 12px; -fx-text-fill: #16a34a;" />
            </children>
        </HBox>
    </top>
    
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <children>
                <!-- Zone de conversation -->
                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" prefHeight="450" 
                           style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8;">
                    <content>
                        <VBox fx:id="chatMessagesContainer" spacing="8" style="-fx-padding: 16;">
                            <!-- Messages seront ajoutés dynamiquement ici -->
                        </VBox>
                    </content>
                </ScrollPane>
                
                <!-- Zone de saisie -->
                <HBox spacing="10" style="-fx-alignment: center;">
                    <children>
                        <TextField fx:id="messageField" promptText="Posez votre question agricole..." 
                                  prefHeight="50" prefWidth="600" style="-fx-background-radius: 25; -fx-border-radius: 25; -fx-border-color: #d1d5db; -fx-padding: 12 20;">
                            <font>
                                <Font size="14" />
                            </font>
                        </TextField>
                        
                        <Button fx:id="sendButton" text="Envoyer" prefHeight="50" prefWidth="100"
                               style="-fx-background-color: #228B22; -fx-background-radius: 25; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;">
                            <font>
                                <Font size="14" />
                            </font>
                        </Button>
                    </children>
                </HBox>
                
                <!-- Message d'aide -->
                <Label text="💡 Conseils : demandez-moi des informations sur les cultures, maladies, engrais, ou calendrier de plantation !" 
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280; -fx-font-style: italic;" />
            </children>
        </VBox>
    </center>
    
    <right>
        <VBox spacing="15" style="-fx-padding: 20 20 20 0; -fx-pref-width: 180;">
            <children>
                <Label text="Questions rapides" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;" />
                
                <VBox spacing="8">
                    <Button fx:id="btnQuestion1" text="🌱 Quand planter les tomates ?" prefWidth="160" prefHeight="35"
                           style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-font-size: 11;" wrapText="true" />
                    
                    <Button fx:id="btnQuestion2" text="🚫 Comment traiter les pucerons ?" prefWidth="160" prefHeight="35"
                           style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-font-size: 11;" wrapText="true" />
                    
                    <Button fx:id="btnQuestion3" text="💧 Fréquence d'arrosage ?" prefWidth="160" prefHeight="35"
                           style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-font-size: 11;" wrapText="true" />
                    
                    <Button fx:id="btnQuestion4" text="🌾 Meilleur engrais NPK ?" prefWidth="160" prefHeight="35"
                           style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-font-size: 11;" wrapText="true" />
                    
                    <Button fx:id="btnQuestion5" text="🥕 Planter pommes de terre ?" prefWidth="160" prefHeight="35"
                           style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-font-size: 11;" wrapText="true" />
                    
                    <Button fx:id="btnQuestion6" text="🌿 Culture bio ?" prefWidth="160" prefHeight="35"
                           style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-font-size: 11;" wrapText="true" />
                </VBox>
                
                <VBox spacing="8" style="-fx-padding-top: 20;">
                    <Button fx:id="clearButton" text="🗑️ Effacer la conversation" prefWidth="160" prefHeight="35"
                           style="-fx-background-color: #fef2f2; -fx-border-color: #fca5a5; -fx-border-radius: 8; -fx-text-fill: #dc2626; -fx-font-size: 11;" />
                    
                    <Button fx:id="backButton" text="← Retour" prefWidth="160" prefHeight="35"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-text-fill: #475569; -fx-font-size: 11;" />
                </VBox>
            </children>
        </VBox>
    </right>
    
</BorderPane>
