<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
        maxHeight="1.7976931348623157E308"
        maxWidth="1.7976931348623157E308"
        prefHeight="720.0"
        prefWidth="1200.0"
        styleClass="user-form-root"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="Controllers.MainGuiAdminController">

    <!-- SIDEBAR -->
    <left>
        <VBox fx:id="MainLeftSidebar"
              alignment="TOP_CENTER"
              prefWidth="260.0"
              style="-fx-background-color: linear-gradient(to bottom, #1a5c1a, #228B22);
                     -fx-background-radius: 0 20 20 0;">

            <padding><Insets top="32" left="20" right="20" bottom="32"/></padding>

            <VBox alignment="CENTER" spacing="4">
                <ImageView fitHeight="80.0" fitWidth="110.0" preserveRatio="true">
                    <image>
                        <Image url="@assets/logoo.png"/>
                    </image>
                </ImageView>
                <Label text="AgriGo"
                       styleClass="user-form-title" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
                <Label text="Administration"
                       style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 11px;" />
            </VBox>

            <Pane prefHeight="1"
                  style="-fx-background-color: rgba(255,255,255,0.2);">
                <VBox.margin><Insets top="24" bottom="24"/></VBox.margin>
            </Pane>

            <Button fx:id="todashboard"
                    text="👥  Gestion Utilisateurs"
                    onAction="#todashboard"
                    prefHeight="52"
                    prefWidth="220"/>

            <Button fx:id="BtnGestionTache"
                    text="📋  Gestion Tâches"
                    onAction="#BtnGestionTache"
                    prefHeight="52"
                    prefWidth="220"/>

            <Button fx:id="btnStats"
                    text="📊  Statistiques"
                    onAction="#openStats"
                    prefHeight="52"
                    prefWidth="220"/>



            <Region VBox.vgrow="ALWAYS"/>

            <Label text="AgriGo v2.0 • Admin"
                   style="-fx-text-fill: rgba(255,255,255,0.3);" />
        </VBox>
    </left>

    <!-- MAIN AREA -->
    <center>
        <BorderPane fx:id="SecondBorderPane">
            <padding><Insets top="24" left="24" right="24" bottom="24"/></padding>

            <!-- TOP BAR -->
            <top>
                <HBox alignment="CENTER_LEFT"
                      prefHeight="64"
                      spacing="10"
                      styleClass="user-form-card"
                             style="-fx-background-radius: 16;
                                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 3);">

                    <padding><Insets left="24" right="16"/></padding>

                    <VBox spacing="2">
                        <Label text="Tableau de bord"
                               styleClass="user-form-title" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                        <Label text="Bienvenue, Administrateur"
                               styleClass="user-form-subtitle" style="-fx-font-size: 12px;" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Profil Menu -->
                    <MenuButton fx:id="btnProfil" text="Admin"
                                style="-fx-background-color: #f0f4f0;
                                       -fx-background-radius: 20;">

                        <graphic>
                            <ImageView fitHeight="28" fitWidth="28" preserveRatio="true">
                                <image>
                                    <Image url="@assets/user.png"/>
                                </image>
                            </ImageView>
                        </graphic>

                        <items>
                            <MenuItem text="📋 Mes tâches" onAction="#openMesTaches"/>
                            <MenuItem text="👤 Mon profil" onAction="#openMonProfil"/>

                            <SeparatorMenuItem/>

                            <MenuItem text="🌾 Jeu Agricole" onAction="#openAgriGame"/>
                            <MenuItem text="🧩 Puzzle Agricole" onAction="#openAgriPuzzle"/>
                            <MenuItem text="🤖 Assistant Agricole" onAction="#openAgriChatbot"/>
                        </items>
                    </MenuButton>

                    <!-- Logout -->
                    <Button fx:id="logout"
                            text="Déconnexion"
                            onAction="#logout"/>
                </HBox>
            </top>

            <!-- CONTENT -->
            <center>
                <VBox spacing="20" alignment="TOP_CENTER">

                    <!-- WELCOME BLOCK -->
                    <VBox alignment="CENTER" spacing="6">
                        <Label text="🌿"
                               style="-fx-font-size: 52px;" />
                        <Label text="Bienvenue sur AgriGo"
                               styleClass="user-form-title"
                               style="-fx-font-size: 26px;
                                      -fx-font-weight: bold;" />
                        <Label text="Consultez et gérez vos tâches agricoles depuis votre espace."
                               styleClass="user-form-subtitle"
                               style="-fx-font-size: 13.5px;" />
                    </VBox>

                    <!-- CARTES STATISTIQUES -->
                    <HBox spacing="16" alignment="CENTER">
                        <VBox prefWidth="220" spacing="6"
                              styleClass="user-form-card"
                                     style="-fx-padding: 20;
                                            -fx-background-radius: 15;">
                            <Label text="👥 Utilisateurs"/>
                            <Label text="248"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                            <Label text="+12 ce mois"/>
                        </VBox>

                        <VBox prefWidth="220" spacing="6"
                              styleClass="user-form-card"
                                     style="-fx-padding: 20;
                                            -fx-background-radius: 15;">
                            <Label text="📋 Tâches actives"/>
                            <Label text="57"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                            <Label text="+5 cette semaine"/>
                        </VBox>

                        <VBox prefWidth="220" spacing="6"
                              styleClass="user-form-card"
                                     style="-fx-padding: 20;
                                            -fx-background-radius: 15;">
                            <Label text="📊 Taux d'achèvement"/>
                            <Label text="84%"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                            <Label text="+3% vs mois dernier"/>
                        </VBox>
                    </HBox>

                </VBox>
            </center>

        </BorderPane>
    </center>

</BorderPane>