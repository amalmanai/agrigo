<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane fx:id="rootPane" prefHeight="820.0" prefWidth="1100.0" styleClass="app-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlles.DashBoardController">
    <Pane styleClass="app-background" />
    <HBox alignment="TOP_LEFT" spacing="18.0" styleClass="app-frame">
        <VBox prefWidth="240.0" styleClass="side-nav">
            <!-- Logo Section -->
            <VBox alignment="CENTER" spacing="8.0" styleClass="logo-section">
                <ImageView fitHeight="72.0" fitWidth="180.0" preserveRatio="true">
                    <image>
                        <Image url="@image/logo.png" />
                    </image>
                </ImageView>
                <VBox alignment="CENTER" spacing="2.0">
                    <Label fx:id="brandTitle" text="Cultures" styleClass="brand-title" style="-fx-text-fill: #ffffff;" />
                    <Label text="Management Suite" styleClass="brand-subtitle" style="-fx-text-fill: rgba(255, 255, 255, 0.7);" />
                </VBox>
                <padding>
                    <Insets top="16.0" bottom="16.0" />
                </padding>
            </VBox>

            <Separator styleClass="nav-separator">
                <VBox.margin>
                    <Insets bottom="12.0" />
                </VBox.margin>
            </Separator>

            <!-- Navigation Section -->
            <VBox spacing="6.0" styleClass="nav-section">
                <Label text="NAVIGATION" styleClass="nav-section-title" style="-fx-text-fill: rgba(255, 255, 255, 0.5);">
                    <padding>
                        <Insets left="16.0" bottom="6.0" />
                    </padding>
                </Label>

                <Button fx:id="btnNavDashboard" onAction="#showDashboard"
                        prefHeight="44.0" maxWidth="Infinity" alignment="CENTER_LEFT">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <SVGPath content="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"
                                     styleClass="nav-icon"
                                     />
                            <Label text="Tableau de bord" styleClass="nav-label" style="-fx-text-fill: #ffffff;" />
                        </HBox>
                    </graphic>
                    <styleClass>
                        <String fx:value="nav-button" />
                        <String fx:value="nav-button-active" />
                    </styleClass>
                </Button>

                <Button fx:id="btnNavCultures" onAction="#showCultures"
                        prefHeight="44.0" maxWidth="Infinity" alignment="CENTER_LEFT">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <ImageView fitWidth="16.0" fitHeight="16.0" preserveRatio="true" smooth="true" styleClass="nav-image-icon">
                                <image>
                                    <Image url="@image/cultures_icon.png" />
                                </image>
                            </ImageView>
                            <Label text="Cultures" styleClass="nav-label" style="-fx-text-fill: rgba(255, 255, 255, 0.7);" />
                        </HBox>
                    </graphic>
                    <styleClass>
                        <String fx:value="nav-button" />
                    </styleClass>
                </Button>

                <Button fx:id="btnNavParcelles" onAction="#showParcelles"
                        prefHeight="44.0" maxWidth="Infinity" alignment="CENTER_LEFT">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <ImageView fitWidth="16.0" fitHeight="16.0" preserveRatio="true" smooth="true" styleClass="nav-image-icon">
                                <image>
                                    <Image url="@image/parcelles_icon.png" />
                                </image>
                            </ImageView>
                            <Label text="Parcelles" styleClass="nav-label" style="-fx-text-fill: rgba(255, 255, 255, 0.7);" />
                        </HBox>
                    </graphic>
                    <styleClass>
                        <String fx:value="nav-button" />
                    </styleClass>
                </Button>

                <Button fx:id="btnNavAnalytics" onAction="#showAnalytics"
                        prefHeight="44.0" maxWidth="Infinity" alignment="CENTER_LEFT">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"
                                     styleClass="nav-icon"
                                     />
                            <Label text="Analytique" styleClass="nav-label" style="-fx-text-fill: rgba(255, 255, 255, 0.7);" />
                        </HBox>
                    </graphic>
                    <styleClass>
                        <String fx:value="nav-button" />
                    </styleClass>
                </Button>
                <VBox.margin>
                    <Insets top="4.0" />
                </VBox.margin>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- Footer Info -->
            <VBox styleClass="nav-footer" spacing="6.0">
                <Separator styleClass="nav-separator">
                    <VBox.margin>
                        <Insets bottom="8.0" />
                    </VBox.margin>
                </Separator>
                <Label text="Version 1.0.0" styleClass="nav-footer-text" style="-fx-text-fill: rgba(255, 255, 255, 0.5);" />
                <Label text="© 2024 Cultures MS" styleClass="nav-footer-text" style="-fx-text-fill: rgba(255, 255, 255, 0.5);" />
                <padding>
                    <Insets top="12.0" bottom="16.0" left="16.0" right="16.0" />
                </padding>
            </VBox>
        </VBox>
        <BorderPane prefHeight="760.0" prefWidth="780.0" styleClass="app-main">
            <top>
                <!-- Friend's user topbar layout, with added search + night/day -->
                <HBox alignment="CENTER_LEFT" styleClass="topbar" spacing="16.0">
                    <!-- Left: title + subtitle -->
                    <VBox spacing="4.0">
                        <Label text="Tableau de bord" styleClass="page-title" />
                        <Label text="Bienvenue dans votre espace" styleClass="page-subtitle" />
                    </VBox>

                    <!-- Center: search bar (cultures filtering) -->
                    <Pane HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" styleClass="search-container" spacing="8.0">
                        <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                 styleClass="search-icon"
                                 />
                        <TextField fx:id="searchField"
                                   promptText="Rechercher une culture ou une parcelle..."
                                   styleClass="search-field"
                                   prefWidth="260.0" />
                    </HBox>
                    <Pane HBox.hgrow="ALWAYS" />

                    <!-- Right: night/day toggle + Mon compte + Déconnexion -->
                    <HBox alignment="CENTER_RIGHT" spacing="10.0">
                        <StackPane styleClass="icon-pill">
                            <Button fx:id="btnThemeToggle" onAction="#toggleTheme" styleClass="icon-button">
                                <graphic>
                                    <ImageView fx:id="themeIconImage" fitWidth="30.0" fitHeight="16.0" preserveRatio="true" smooth="true" mouseTransparent="true">
                                        <image>
                                            <Image url="@image/day_toggle.png" />
                                        </image>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </StackPane>

                        <MenuButton fx:id="btnProfil"
                                    text="Mon compte"
                                    style="-fx-background-color:#f0f4f0; -fx-background-radius:20;">
                            <items>
                                <MenuItem text="📋 Mes tâches" onAction="#openMesTaches"/>
                                <MenuItem text="👤 Mon profil" onAction="#openMonProfil"/>
                                <MenuItem text="🎮 Jeu Agricole" onAction="#openAgriGame"/>
                                <MenuItem text="🧩 Puzzle Agricole" onAction="#openAgriPuzzle"/>
                                <MenuItem text="🤖 Assistant Agricole" onAction="#openAgriChatbot"/>
                            </items>
                        </MenuButton>

                        <Button fx:id="logoutuser"
                                onAction="#logoutuser"
                                style="-fx-background-color:#ffeded; -fx-text-fill:#c0392b; -fx-background-radius:10;"
                                text="Déconnexion" />
                    </HBox>
                </HBox>
            </top>

    <center>
        <VBox styleClass="content-area" spacing="20.0">
            <!-- Stats Cards -->
            <HBox spacing="16.0" styleClass="stats-container">
                <VBox prefWidth="220.0" styleClass="stat-card" spacing="12.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" smooth="true" styleClass="stat-image-icon">
                            <image>
                                <Image url="@image/cultures_actives_icon.png" />
                            </image>
                        </ImageView>
                        <Label text="CULTURES ACTIVES" styleClass="stat-title" />
                    </HBox>
                    <Label text="24" styleClass="stat-value" />
                    <HBox alignment="CENTER_LEFT" spacing="6.0">
                        <SVGPath content="M7 14l5-5 5 5z" styleClass="stat-trend-icon stat-trend-up"
                                 />
                        <Label text="+8% ce mois" styleClass="stat-note stat-note-positive" />
                    </HBox>
                    <padding>
                        <Insets top="18.0" bottom="18.0" left="18.0" right="18.0" />
                    </padding>
                </VBox>

                <VBox prefWidth="220.0" styleClass="stat-card" spacing="12.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" smooth="true" styleClass="stat-image-icon">
                            <image>
                                <Image url="@image/rendement_moyen_icon.png" />
                            </image>
                        </ImageView>
                        <Label text="RENDEMENT MOYEN" styleClass="stat-title" />
                    </HBox>
                    <Label text="540 kg" styleClass="stat-value" />
                    <HBox alignment="CENTER_LEFT" spacing="6.0">
                        <SVGPath content="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                                 styleClass="stat-trend-icon stat-trend-stable"
                                 />
                        <Label text="Stable sur 30 jours" styleClass="stat-note stat-note-neutral" />
                    </HBox>
                    <padding>
                        <Insets top="18.0" bottom="18.0" left="18.0" right="18.0" />
                    </padding>
                </VBox>

                <VBox prefWidth="220.0" styleClass="stat-card" spacing="12.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" smooth="true" styleClass="stat-image-icon">
                            <image>
                                <Image url="@image/parcelles_supervisees_icon.png" />
                            </image>
                        </ImageView>
                        <Label text="PARCELLES SUPERVISÉES" styleClass="stat-title" />
                    </HBox>
                    <Label text="12" styleClass="stat-value" />
                    <HBox alignment="CENTER_LEFT" spacing="6.0">
                        <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                                 styleClass="stat-trend-icon stat-trend-alert"
                                 />
                        <Label text="2 zones prioritaires" styleClass="stat-note stat-note-warning" />
                    </HBox>
                    <padding>
                        <Insets top="18.0" bottom="18.0" left="18.0" right="18.0" />
                    </padding>
                </VBox>
            </HBox>

            <!-- Tabs Section -->
            <TabPane fx:id="mainTabs" prefHeight="600.0" styleClass="main-tabs">
                <tabs>
                    <Tab fx:id="tabDashboard" text="" closable="false">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8.0">
                                <SVGPath content="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"
                                         styleClass="tab-icon" />
                                <Label text="Tableau de bord" styleClass="tab-label" />
                            </HBox>
                        </graphic>
                        <content>
                            <VBox spacing="16.0" styleClass="tab-content">
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <Label text="Aperçu des alertes de risques" styleClass="section-title" />
                                </HBox>

                                <TableView fx:id="tableAlertes" prefHeight="540.0" styleClass="data-table">
                                    <columns>
                                        <TableColumn fx:id="colAId" prefWidth="60.0" text="ID" styleClass="table-col-id" />
                                        <TableColumn fx:id="colADate" prefWidth="180.0" text="DATE M. À J." styleClass="table-col-text" />
                                        <TableColumn fx:id="colAType" prefWidth="180.0" text="NIVEAU/TYPE" styleClass="table-col-status" />
                                        <TableColumn fx:id="colADesc" prefWidth="380.0" text="DESCRIPTION DU RISQUE" styleClass="table-col-text" />
                                        <TableColumn fx:id="colACulture" prefWidth="180.0" text="CULTURE ASSOCIÉE" styleClass="table-col-text" />
                                    </columns>
                                </TableView>
                                <padding>
                                    <Insets top="12.0" bottom="12.0" left="12.0" right="12.0" />
                                </padding>
                            </VBox>
                        </content>
                    </Tab>

                    <Tab fx:id="tabCultures" text="" closable="false">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8.0">
                                <ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" smooth="true" styleClass="tab-image-icon">
                                    <image>
                                        <Image url="@image/cultures_icon.png" />
                                    </image>
                                </ImageView>
                                <Label text="Cultures" styleClass="tab-label" />
                            </HBox>
                        </graphic>
                        <content>
                            <VBox spacing="16.0" styleClass="tab-content">
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <Label text="Gestion des cultures" styleClass="section-title" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#ajouterCulture"
                                            prefHeight="38.0" styleClass="primary-button">
                                        <graphic>
                                            <HBox alignment="CENTER" spacing="6.0">
                                                <SVGPath content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                                                         styleClass="button-icon"
                                                         />
                                                <Label text="Ajouter une culture" styleClass="button-label" style="-fx-text-fill: #ffffff;" />
                                            </HBox>
                                        </graphic>
                                    </Button>
                                </HBox>

                                <TableView fx:id="tableCultures" prefHeight="520.0" styleClass="data-table">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="70.0" text="ID" styleClass="table-col-id" />
                                        <TableColumn fx:id="colNom" prefWidth="250.0" text="NOM DE LA CULTURE" styleClass="table-col-text" />
                                        <TableColumn fx:id="colEtat" prefWidth="210.0" text="ETAT DE CROISSANCE" styleClass="table-col-status" />
                                        <TableColumn fx:id="colRendement" prefWidth="190.0" text="RENDEMENT (KG)" styleClass="table-col-number" />
                                        <TableColumn fx:id="colActions" prefWidth="120.0" text="ACTIONS" styleClass="table-col-actions" />
                                    </columns>
                                </TableView>
                                <padding>
                                    <Insets top="12.0" bottom="12.0" left="12.0" right="12.0" />
                                </padding>
                            </VBox>
                        </content>
                    </Tab>

                    <Tab fx:id="tabParcelles" text="" closable="false">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8.0">
                                <ImageView fitWidth="18.0" fitHeight="18.0" preserveRatio="true" smooth="true" styleClass="tab-image-icon">
                                    <image>
                                        <Image url="@image/parcelles_icon.png" />
                                    </image>
                                </ImageView>
                                <Label text="Parcelles" styleClass="tab-label" />
                            </HBox>
                        </graphic>
                        <content>
                            <VBox spacing="16.0" styleClass="tab-content">
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <Label text="Gestion des parcelles" styleClass="section-title" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#ajouterParcelle"
                                            prefHeight="38.0" styleClass="primary-button">
                                        <graphic>
                                            <HBox alignment="CENTER" spacing="6.0">
                                                <SVGPath content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                                                         styleClass="button-icon"
                                                         />
                                                <Label text="Ajouter une parcelle" styleClass="button-label" style="-fx-text-fill: #ffffff;" />
                                            </HBox>
                                        </graphic>
                                    </Button>
                                </HBox>

                                <TableView fx:id="tableParcelles" prefHeight="520.0" styleClass="data-table">
                                    <columns>
                                        <TableColumn fx:id="colPId" prefWidth="70.0" text="ID" styleClass="table-col-id" />
                                        <TableColumn fx:id="colPNom" prefWidth="270.0" text="NOM DE LA PARCELLE" styleClass="table-col-text" />
                                        <TableColumn fx:id="colPSurface" prefWidth="170.0" text="SURFACE (HA)" styleClass="table-col-number" />
                                        <TableColumn fx:id="colPType" prefWidth="210.0" text="TYPE DE SOL" styleClass="table-col-status" />
                                        <TableColumn fx:id="colPActions" prefWidth="120.0" text="ACTIONS" styleClass="table-col-actions" />
                                    </columns>
                                </TableView>
                                <padding>
                                    <Insets top="12.0" bottom="12.0" left="12.0" right="12.0" />
                                </padding>
                            </VBox>
                        </content>
                    </Tab>

                    <Tab fx:id="tabAnalytics" text="" closable="false">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8.0">
                                <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"
                                         styleClass="tab-icon" />
                                <Label text="Analytique" styleClass="tab-label" />
                            </HBox>
                        </graphic>
                        <content>
                            <ScrollPane fitToWidth="true" styleClass="edge-to-edge">
                                <VBox spacing="18.0" styleClass="tab-content">
                                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                                        <Label text="Analytique &amp; météo" styleClass="section-title" />
                                    </HBox>

                                <!-- Basic analytics cards -->
                                <HBox spacing="16.0" styleClass="stats-container">
                                    <VBox prefWidth="220.0" styleClass="stat-card" spacing="10.0">
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <SVGPath content="M12 2l3 5.2 5.8.8-4.2 4.1 1 5.9L12 15.9 6.4 18l1-5.9-4.2-4.1 5.8-.8z"
                                                     styleClass="stat-icon-primary" />
                                            <Label text="CULTURES" styleClass="stat-title" />
                                        </HBox>
                                        <Label fx:id="lblTotalCultures" text="0" styleClass="stat-value" />
                                    </VBox>

                                    <VBox prefWidth="220.0" styleClass="stat-card" spacing="10.0">
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <SVGPath content="M4 9l8-7 8 7v10a2 2 0 0 1-2 2h-4v-6H10v6H6a2 2 0 0 1-2-2z"
                                                     styleClass="stat-icon-success" />
                                            <Label text="PARCELLES" styleClass="stat-title" />
                                        </HBox>
                                        <Label fx:id="lblTotalParcelles" text="0" styleClass="stat-value" />
                                    </VBox>

                                    <VBox prefWidth="220.0" styleClass="stat-card" spacing="10.0">
                                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                                            <SVGPath content="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 14h-2v-2h2v2zm0-4h-2V6h2v6z"
                                                     styleClass="stat-icon-warning" />
                                            <Label text="ALERTES" styleClass="stat-title" />
                                        </HBox>
                                        <Label fx:id="lblTotalAlertes" text="0" styleClass="stat-value" />
                                    </VBox>
                                </HBox>

                                <!-- Section: Weather Risk -->
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <Label text="Prévision des risques météo pour :" styleClass="section-title" />
                                    <ComboBox fx:id="comboParcelleSelect" promptText="Choisir une parcelle..." prefWidth="250.0" styleClass="combo-box-base"/>
                                </HBox>
                                <StackPane fx:id="weatherRiskCard" styleClass="weather-risk-card risk-level-green">
                                    <VBox spacing="8.0">
                                        <Label fx:id="lblWeatherRiskTitle"
                                               text="Niveau global : Vert — Faible"
                                               styleClass="weather-risk-title" />
                                        <Label fx:id="lblWeatherRiskDetail"
                                               text="Veuillez sélectionner une parcelle pour voir les risques détaillés."
                                               wrapText="true"
                                               styleClass="weather-risk-detail" />
                                    </VBox>
                                </StackPane>
                                <!-- Color legend -->
                                <HBox spacing="8.0">
                                    <StackPane styleClass="legend-chip risk-level-green">
                                        <Label text="Vert (faible)" styleClass="legend-label" />
                                    </StackPane>
                                    <StackPane styleClass="legend-chip risk-level-yellow">
                                        <Label text="Jaune (surveillance)" styleClass="legend-label" />
                                    </StackPane>
                                    <StackPane styleClass="legend-chip risk-level-red">
                                        <Label text="Rouge (élevé)" styleClass="legend-label" />
                                    </StackPane>
                                    <StackPane styleClass="legend-chip risk-level-dark-red">
                                        <Label text="Rouge foncé (critique)" styleClass="legend-label" />
                                    </StackPane>
                                </HBox>

                                <!-- Predictions Section -->
                                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                                    <Label text="✨ Moteur IA de Prédiction des Rendements" styleClass="section-title" style="-fx-text-fill: #a855f7;" />
                                    <TableView fx:id="tablePredictions" prefHeight="250.0" VBox.vgrow="ALWAYS" styleClass="data-table">
                                        <columns>
                                            <TableColumn fx:id="colPredParcelle" prefWidth="150.0" text="PARCELLE" styleClass="table-col-text" />
                                            <TableColumn fx:id="colPredCulture" prefWidth="150.0" text="CULTURE" styleClass="table-col-text" />
                                            <TableColumn fx:id="colPredBase" prefWidth="110.0" text="BASE (T/Ha)" styleClass="table-col-number" />
                                            <TableColumn fx:id="colPredPrevu" prefWidth="110.0" text="PRÉVU (T/Ha)" styleClass="table-col-number" />
                                            <TableColumn fx:id="colPredImpact" prefWidth="100.0" text="IMPACT" styleClass="table-col-status" />
                                            <TableColumn fx:id="colPredConfidence" prefWidth="120.0" text="CONFIANCE IA" styleClass="table-col-status" />
                                            <TableColumn fx:id="colPredRecommendation" prefWidth="250.0" text="RECOMMANDATION" styleClass="table-col-text" />
                                        </columns>
                                    </TableView>
